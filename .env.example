# Copy to .env to override defaults for local runs.

# SQLAlchemy async URL.
#   Local (zero infra):  sqlite+aiosqlite:///./approval.db
#   PostgreSQL:           postgresql+asyncpg://approval:approval@localhost:5432/approval
DATABASE_URL=sqlite+aiosqlite:///./approval.db

LOG_LEVEL=INFO

# Create tables on startup instead of running Alembic migrations.
# Leave false when using migrations (the default for docker-compose).
AUTO_CREATE_TABLES=false
